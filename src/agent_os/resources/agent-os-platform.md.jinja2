## Config (`agent-os.toml`) Quick Reference

Key sections (full schema in `src/agent_os/config.py`):

```toml
[company]
name = "Your Company"
timezone = "UTC"

[runtime]
model = "claude-sonnet-4-6"
user = "corvyd"                  # Service account (for systemd deployments)
env_file = "/etc/agent-os.env"   # systemd EnvironmentFile, for doctor

[project]                        # Enables the workspace SDLC
default_branch = "main"
push = true
[project.setup]
commands = ["npm install"]
[project.validate]
commands = ["pytest", "ruff check ."]
on_failure = "retry"
max_retries = 2
[project.commit]                 # Injected inline at commit time; no global
author_email = "agent-os@example.com"   # git config needs to be set on the host
author_name = "agent-os"
# Optional per-agent attribution:
# [project.commit.agent_authors.agent-001-maker]
# email = "maker@example.com"
# name   = "The Maker"

[budget]
task = 5.00
daily_cap = 100.00
weekly_cap = 500.00

[schedule]
enabled = true
[schedule.cycles]
interval_minutes = 15

[notifications]
enabled = true
webhook_url = "..."              # Slack/Discord/etc
min_severity = "warning"

[circuit_breaker]
enabled = true
max_failures = 5
cooldown_minutes = 60
```

